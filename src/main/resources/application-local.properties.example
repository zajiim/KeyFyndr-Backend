# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT SECRETS TEMPLATE
# Copy this file to application-local.properties and fill in real values.
# The .example file IS committed to git. The actual file is NOT.
#
# Usage:
#   cp application-local.properties.example application-local.properties
#   # Edit application-local.properties with your actual credentials
#   # Run the app with: ./gradlew bootRun --args='--spring.profiles.active=local'
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/mydatabase
DB_USERNAME=<your_db_username>
DB_PASSWORD=<your_db_password>

# Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379

# JWT
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=<your_base64_256bit_jwt_secret>

# Firebase
# Set to the path of your service-account.json (relative to classpath root, or absolute path)
FIREBASE_SERVICE_ACCOUNT_PATH=service-account.json

# Mapbox Static Images API
# Get your token at https://account.mapbox.com → Tokens
MAPBOX_API=<your_mapbox_pk_token>
